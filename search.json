---
layout: null
---

[
{% for post in site.posts %}
  {
    "title": "{{ post.title | escape }}",
    "url": "{{ post.url }}",
    "date": "{{ post.date | date: "%Y-%m-%d" }}",
    "excerpt": "{{ post.excerpt | strip_html | escape }}",
    "tags": [
      {% for tag in post.tags %}
        "{{ tag }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]